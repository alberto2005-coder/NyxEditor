{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ES2022",
        "outDir": "out",
        "lib": ["ES2022", "DOM"],
        "sourceMap": true,
        "strict": true,
        "rootDir": "src",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "NodeNext",
        "types": ["node"]
    },
    "include": ["src"]
}
