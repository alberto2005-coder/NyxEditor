{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": [
            "ES2020",
            "dom"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": [
        "src/**/*",
        "../../src/vscode-dts/vscode.d.ts"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}
